{
  "name": "tciv-client",
  "version": "0.0.6",
  "description": "HTTP client for TCIV-series intercom systems (TCIV-2+, TCIV-3). Control relays, SIP configuration, DAK provisioning, webcall, audio settings, and camera feeds.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./scanner": {
      "import": {
        "types": "./dist/scanner.d.ts",
        "default": "./dist/scanner.js"
      },
      "require": {
        "types": "./dist/scanner.d.ts",
        "default": "./dist/scanner.js"
      }
    }
  },
  "bin": {
    "tciv": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "cli": "tsx src/cli.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.21.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "intercom",
    "TCIV",
    "SIP",
    "door-access",
    "relay",
    "DTMF",
    "webcall",
    "building-automation",
    "tciv-client"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pinecall/tciv-client"
  },
  "homepage": "https://github.com/pinecall/tciv-client#readme",
  "bugs": {
    "url": "https://github.com/pinecall/tciv-client/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
